# SQLite Local-First Connection String
SQLALCHEMY_DATABASE_URL=sqlite:///./platform.db

# Allowed CORS Origins (JSON list)
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Google Application Credentials (JSON key file path for Earth Engine Service Account)
# GOOGLE_APPLICATION_CREDENTIALS=/app/credentials.json

# Earth Engine Buffer Zone in kilometers
GEE_BUFFER_KM=50.0

# Path to the Google Earth Engine Service Account JSON credentials file
GEE_SERVICE_ACCOUNT_KEY=backend/credentials/gee-service-account.json
